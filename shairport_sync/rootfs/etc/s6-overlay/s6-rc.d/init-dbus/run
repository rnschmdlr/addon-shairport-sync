#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Addon: Shairport Sync
# Ensures we have a unique D-Bus ID
# ==============================================================================

bashio::log.info "Generating D-Bus UUID..."
dbus-uuidgen --ensure || bashio::exit.nok 'Failed to generate a unique D-Bus ID'

# Clean up stale PID file left by an ungraceful previous shutdown
mkdir -p /run/dbus
rm -f /run/dbus/dbus.pid
